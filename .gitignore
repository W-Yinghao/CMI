# --- large / binary / transient: keep the repo to code + docs + result JSONs ---
# third-party papers (copyrighted PDFs, 147M)
papers/
*.pdf

# SLURM logs (transient, 13M)
logs/
*.out
*.err
*.pid

# third-party cloned repos (have their own upstream/licenses)
repos/

# large binary result/data files (keep the .json, drop the arrays)
*.npz
*.preds.npz
*.npy
*.pt
*.pth
*.ckpt

# CIGL Phase 2-real / Phase 3A / 3A-R generated run artifacts (exploratory, regenerable; keep READMEs)
results/cigl/phase2_real/*.json
results/cigl/phase3a_pilot/*.json
results/cigl/phase3a_baseline_repair/*.json
results/cigl/phase3a_backbone_sanity/*.json
results/cigl/phase3a_graph_backbone_redesign/*.json
results/cigl/phase3a_dgcnn_leakage_audit/*.json
results/cigl/phase3a_dgcnn_gn_regularizer_pilot/*.json
results/cigl/phase3a_dgcnn_gn_multifold_confirmation/*.json
results/cigl/phase3a_dgcnn_gn_second_dataset_confirmation/*.json
# Phase 4A generated paper tables (regenerable from tracked docs/JSON; keep gitignored unless approved)
results/cigl/paper_tables/
# CIGL_46 Graph-DualCMI G2 pilot: commit only the reviewable evidence
#   (*.json per-run summaries + G2_SUMMARY.md + G2_AGGREGATE.csv).
# Prediction sidecars / checkpoints / slurm logs are excluded (also covered globally above);
# re-stated here dir-scoped for reviewer clarity (PI gate 2026-07-01).
results/graphdualcmi_pilot/*.preds.npz
results/graphdualcmi_pilot/*.ckpt
results/graphdualcmi_pilot/*.pt
results/graphdualcmi_pilot/*.out

# python caches
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# editor / os
.DS_Store
.vscode/
*.swp

# slurm generated packages that reference local paths (optional; keep templates)
slurm-*.out

# CIGL LaTeX compile-smoke artifacts (never commit generated build output)
paper/cigl_latex/_build/
paper/cigl_latex/**/*.aux
paper/cigl_latex/**/*.bbl
paper/cigl_latex/**/*.blg
paper/cigl_latex/**/*.log
paper/cigl_latex/**/*.out
paper/cigl_latex/**/*.fls
paper/cigl_latex/**/*.fdb_latexmk
paper/cigl_latex/**/*.synctex.gz

# CIGL v0.6 manuscript artifacts (PDF + planning docs; belong to the project/cigl line, regenerable)
cigl_manu/
