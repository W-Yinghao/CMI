# --- large / binary / transient: keep the repo to code + docs + result JSONs ---
# third-party papers (copyrighted PDFs, 147M)
papers/
*.pdf

# SLURM logs (transient, 13M)
logs/
*.out
*.err
*.pid

# third-party cloned repos (have their own upstream/licenses)
repos/

# large binary result/data files (keep the .json, drop the arrays)
*.npz
*.preds.npz
*.npy
*.pt
*.pth
*.ckpt

# python caches
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# editor / os
.DS_Store
.vscode/
*.swp

# slurm generated packages that reference local paths (optional; keep templates)
slurm-*.out

# ACAR v4 compute artifacts + detached preflight worktrees (the sandbox surfaces $HOME
# absolute paths inside this tree; the authoritative copies live at $HOME on the cluster).
# Recorded by path+hash in the notes; never committed. Root-anchored so acar/ (the package)
# and results/ (tracked) are unaffected.
/acar_v4_*/
/ACAR_V4_*_PREFLIGHT_*/
/_g1.log
