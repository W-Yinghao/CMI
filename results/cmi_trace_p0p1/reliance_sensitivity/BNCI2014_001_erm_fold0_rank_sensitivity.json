  "algorithm": {
    "estimand": "R_rel(k) = task balanced-accuracy drop when the source-fit k-dim subject subspace is removed from the frozen representation (head-replay counterfactual).",
    "subspace_construction": {
      "label_conditional": "rows sqrt(n_{y,d})*(mean(z|y,d)-mu_y); top-k right singular vectors",
