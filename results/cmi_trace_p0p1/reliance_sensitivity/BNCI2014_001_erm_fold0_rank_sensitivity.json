      "random_subspace": "top-k right singular vectors of a seeded Gaussian matrix (control)"
    },
    "within_label_centering_rule": "subtract the per-label mean mu_y before the subject offset (label_conditional); global mean (marginal_domain); none (random_subspace)",
    "metric_whitening_rule": "raw Euclidean (no whitening); orthonormal top-k right singular vectors; removal P = I - dirs^T dirs applied in the same raw metric",
